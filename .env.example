# Strapi Configuration
STRAPI_URL=http://localhost:1337
STRAPI_ADMIN_EMAIL=admin@newswire.local
STRAPI_ADMIN_PASSWORD=Admin1234!

# Optional: API Token (alternative to admin credentials)
# Generate at: http://localhost:1337/admin/settings/api-tokens
# STRAPI_API_TOKEN=your_token_here

# News API Keys (Optional - for API-based fetching)
NEWSAPI_KEY=
GUARDIAN_API_KEY=
NYTIMES_API_KEY=

# Scraper Settings
SCRAPER_DELAY=2000
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
