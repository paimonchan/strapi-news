{
  "kind": "collectionType",
  "collectionName": "sources",
  "info": {
    "singularName": "source",
    "pluralName": "sources",
    "displayName": "Source",
    "description": "News sources"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true,
      "minLength": 2,
      "maxLength": 100
    },
    "url": {
      "type": "string",
      "required": true,
      "unique": true,
      "regex": "^(http|https)://[^\\\\s$.?#].[^\\\\s]*$"
    },
    "description": {
      "type": "text"
    },
    "news_articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::news.news",
      "mappedBy": "source"
    }
  }
}
