{
  "kind": "collectionType",
  "collectionName": "news_items",
  "info": {
    "singularName": "news",
    "pluralName": "news-articles",
    "displayName": "News",
    "description": "Summarized news from multiple sources"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "minLength": 3,
      "maxLength": 250
    },
    "summary": {
      "type": "text",
      "required": true
    },
    "url": {
      "type": "string",
      "required": true,
      "unique": true,
      "regex": "^(http|https):\\/\\/[a-zA-Z0-9-.]+\\.[a-zA-Z]{2,}(?:\\/[^\\s]*)?$"
    },
    "publishedAt": {
      "type": "datetime",
      "required": false
    },
    "source": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::source.source",
      "inversedBy": "news_articles"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "news_articles"
    }
  }
}
